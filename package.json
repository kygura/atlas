{
  "name": "atlas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "normalize": "bun run src/cli/normalize.ts",
    "annotate": "bun run src/cli/annotate.ts",
    "format": "bun run src/cli/format.ts",
    "deliver": "bun run src/cli/deliver.ts",
    "configure": "bun run src/cli/configure.ts",
    "wishlist": "bun run src/cli/wishlist.ts",
    "promote": "bun run src/cli/promote.ts",
    "frontend:dev": "cd frontend && bun run dev",
    "frontend:build": "cd frontend && bun run build"
  },
  "dependencies": {
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "bun-types": "^1.3.13",
    "typescript": "^5.8.3"
  }
